[Desktop Entry]
Type=Application
Version=1.0
Name=Install MGS Master Collection Mods
Comment=One-click vanilla-faithful mod setup for MGS1, MGS2 & MGS3 Master Collection on Steam Deck / SteamOS
Icon=applications-games
Terminal=true
Exec=bash -c 'TAG=v1.1.0; SHA=21c59c79d63f234b10988eb120fd7e2b0dd130e53ff14e8b1dea12c26da22066; URL=https://github.com/cntrl-alt-lenny/mgs-mc-deck-modkit/releases/download/$TAG/install.py; F=/tmp/mgs_install.py; if curl -fsSL "$URL" -o "$F" && echo "$SHA  $F" | sha256sum -c --status -; then python3 "$F" --desktop "%k"; else echo; echo "Installer download or SHA-256 verification FAILED — nothing was run. (Is release $TAG published?)"; fi; echo; echo "Press Enter to close."; read'
Categories=Game;Utility;
